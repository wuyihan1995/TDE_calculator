#==============================================================================
# in.ed.equilibrate.lmp - One-time equilibration for Ed calculation
#
# Variables (passed from command line):
#   CONFIG_SOURCE - "auto" = generate random alloy; "custom" = read data files
#   N_ELEMENTS    - Number of element types (1=N for single element; N>1 for alloy)
#   TEMP          - Temperature in K (default 40)
#   CONFIG        - Configuration index (1,2,3...) for multi-config run
#   DATA_OUT      - Output data file name
#   LCO_DATA      - Custom data file (e.g. "data.mc.1"), only used if CONFIG_SOURCE=custom
#   POTENTIAL     - Potential file name
#   ELEMENTS      - Element symbols for pair_coeff
#   LATTICE       - Lattice constant in Angstrom
#==============================================================================

units           metal
boundary        p p p
atom_style      atomic
atom_modify     map array sort 5000 2


##-- Configuration setup ------------------------------------------------------
##  custom: read pre-existing data file from user
##  auto:   build BCC lattice (1 element if N_ELEMENTS=1; random alloy if N>1)

if "${CONFIG_SOURCE} == custom" then "read_data ${LCO_DATA}"

if "${CONFIG_SOURCE} != custom" then "variable alat equal ${LATTICE}"
if "${CONFIG_SOURCE} != custom" then "lattice ${CRYSTAL_STRUCTURE} ${alat}"
if "${CONFIG_SOURCE} != custom" then "variable Nsize equal 16"
if "${CONFIG_SOURCE} != custom" then "variable box_bound equal ${Nsize}*${alat}"
if "${CONFIG_SOURCE} != custom" then "variable fill_bound equal ${box_bound}-0.1"
if "${CONFIG_SOURCE} != custom" then "region boxreg block 0 ${box_bound} 0 ${box_bound} 0 ${box_bound} units box"
if "${CONFIG_SOURCE} != custom" then "region fillreg block 0 ${fill_bound} 0 ${fill_bound} 0 ${fill_bound} units box"

if "${CONFIG_SOURCE} != custom" then "create_box ${N_ELEMENTS} boxreg"
if "${CONFIG_SOURCE} != custom" then "create_atoms 1 region fillreg"

##  Random substitution for multi-element auto modes (N_ELEMENTS > 1)
##  The include file is generated by run_Ed.sh for each config.
if "${CONFIG_SOURCE} != custom" then "include rss_substitute.lmp"


##-- Potential setup -----------------------------------------------------------
pair_style      eam/alloy
pair_coeff      * * ${POTENTIAL} ${ELEMENTS}

neighbor        2.0 bin
neigh_modify    every 10 delay 10 check yes


##-- Equilibration -------------------------------------------------------------
thermo          10
thermo_style    custom step temp ke pe pxx pyy pzz lx ly lz
thermo_modify   lost warn

##  CG minimization
fix             relax all box/relax iso 0.0
min_style       cg
minimize        1.0e-6 1.0e-6 10000 10000
unfix           relax

##  NPT at target temperature
timestep        1e-3
velocity        all create ${TEMP} 5659 dist gaussian
fix             setting all npt temp ${TEMP} ${TEMP} $(100.0*dt) iso 1 1 $(100.0*dt) drag 1.0
run             10000
unfix           setting
fix             setting all npt temp ${TEMP} ${TEMP} $(100.0*dt) x 1 1 $(100.0*dt) y 1 1 $(100.0*dt) z 1 1 $(100.0*dt) drag 1.0
run             10000
unfix           setting


##-- Write equilibrated state --------------------------------------------------
write_data      ${DATA_OUT} nocoeff nofix

print           "EQUILIBRATION_COMPLETE: ${ALLOY_NAME} config ${CONFIG} at ${TEMP} K"
